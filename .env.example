# GCP project / location / Vertex flag are auto-detected from gcloud
# Application Default Credentials by agents/__init__.py — uncomment to override.
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_GENAI_USE_VERTEXAI=True

# Model used by the zero-shot predictor agent.
ZERO_SHOT_MODEL=gemini-2.5-flash

# A2A ports per agent — read by each agent's `a2a_app = to_a2a(..., port=…)`
# and by the Makefile's `make run-a2a NAME=<name>` target.
# Convention: <AGENT_NAME_UPPER>_A2A_PORT.
ORCHESTRATOR_A2A_PORT=8000
ZERO_SHOT_A2A_PORT=8001
FINE_TUNED_A2A_PORT=8002
EXPLAINER_A2A_PORT=8003

# MCP tool server (shared across agents) — exposes predict/explain/etc.
# Read by `make run-mcp` and by each agent's tools.py manifest.
MCP_SERVER_PORT=8004

# ── Fine-tuning (Vertex AI Gemini SFT) ────────────────────────────────────
# GCS bucket used to upload train/val JSONL for SFT (must exist in your project).
GCS_BUCKET=
# Base model for SFT and SFT hyperparameters (defaults to lite for cost).
FINE_TUNED_BASE_MODEL=gemini-2.5-flash-lite
FINE_TUNED_EPOCHS=5
FINE_TUNED_ADAPTER_SIZE=ADAPTER_SIZE_SIXTEEN
FINE_TUNED_LRM=1.0
# Filled in AFTER the SFT job finishes — set this so the fine-tuned predictor agent picks it up.
FINE_TUNED_MODEL=
