# Cloud Run image for the truthfulness MCP server.
# Cloud Run injects $PORT (defaults to 8080); uvicorn binds to it.
#
# Build + deploy via `make deploy-mcp` (or `gcloud run deploy --source .`).

FROM python:3.13-slim

# uv for fast, reproducible installs from uv.lock.
RUN pip install --no-cache-dir uv

WORKDIR /app

# Install dependencies first (cached layer — only re-runs when pyproject/uv.lock change).
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project

# Copy only the runtime sources (deploy paths). Notebooks, scripts, and data
# are excluded via .gcloudignore so they don't bloat the build context.
COPY mcp_server/ ./mcp_server/
COPY services/ ./services/

# Final sync — installs the project itself now that the package code is present.
RUN uv sync --frozen

ENV PORT=8080
EXPOSE 8080

CMD uv run uvicorn mcp_server.server:app --host 0.0.0.0 --port ${PORT}
