# Cloud Run image for the unified truthfulness stack (MCP + 4 Agents).
# Cloud Run injects $PORT (defaults to 8080); uvicorn binds to it.

FROM python:3.13-slim

# Install uv for fast, reproducible dependencies
RUN pip install --no-cache-dir uv

WORKDIR /app

# Copy dependency manifests first to leverage Docker build caching
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project

# Copy packages and sources
COPY mcp_server/ ./mcp_server/
COPY services/ ./services/
COPY agents/ ./agents/
COPY deploy/ ./deploy/

# Final sync to install the project itself
RUN uv sync --frozen

ENV PORT=8080
EXPOSE 8080

CMD uv run uvicorn deploy.unified_app:app --host 0.0.0.0 --port ${PORT}
